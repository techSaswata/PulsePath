# PulsePath — Environment Configuration
# Copy to .env.local and fill in the values.

# LLM (OpenAI-compatible) — must support forced tool calling / structured output.
# Fast options: Google gemini-2.5-flash (base below), or OpenRouter gpt-5.4-nano.
# Avoid reasoning models (slow per call). Google base: https://generativelanguage.googleapis.com/v1beta/openai
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=8192              # high: avoids truncated output

# Embeddings (free HuggingFace)
EMBED_PROVIDER=hf-router
EMBED_BASE_URL=https://router.huggingface.co
EMBED_MODEL=BAAI/bge-base-en-v1.5
EMBED_DIMS=768                    # must match model
HF_TOKEN=
EMBED_QUERY_PREFIX=Represent this sentence for searching relevant passages:

# Sarvam AI (voice STT + TTS)
SARVAM_API_KEY=
SARVAM_BASE_URL=https://api.sarvam.ai
SARVAM_STT_MODEL=saarika:v2.5
SARVAM_TTS_MODEL=bulbul:v2
SARVAM_TTS_SPEAKER=anushka
SARVAM_TTS_LANGUAGE=en-IN
SARVAM_TTS_SAMPLE_RATE=22050

# Qdrant (vector DB)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_GUIDELINES_COLLECTION=clinical_guidelines
QDRANT_CASES_COLLECTION=patient_cases

# Supabase (database)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_NAME=PulsePath
CRON_SECRET=
